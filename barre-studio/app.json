{
  "expo": {
    "name": "barre-studio",
    "slug": "barre-studio",
    "orientation": "default",
    "scheme": "barrestudio",
    "plugins": ["expo-router"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "infoPlist": {
        "NSMotionUsageDescription": "Para contar tus pasos diarios.",
        "NSLocationWhenInUseUsageDescription": "Para mostrar la ubicación del estudio."
      }
    },
    "android": {
      "permissions": ["ACTIVITY_RECOGNITION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-video", "@react-native-community/datetimepicker"]
  }
}
